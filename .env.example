# Copy to .env for local development. Render injects production values.

# Flask session signing. Generate a real value for production.
SECRET_KEY=REPLACE_ME

# Local dev defaults to a SQLite file at the project root if unset.
# For Postgres, use: postgresql://user:pass@host:5432/blackjack
# DATABASE_URL=

# Optional: override Flask debug behavior.
# FLASK_DEBUG=1
